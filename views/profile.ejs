<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="p-5 gap-5 flex flex-col justify-start items-start h-full lg:h-screen bg-zinc-900 w-full py-20">
        <a href="/logout" class=" absolute top-27 right-10 bg-red-700 py-1 px-4 text-white rounded-lg"> Logout</a>
        <h1 class=" text-4xl text-bold text-white font-bold"><span class="font-semibold">Hello,</span>
            <%= user.username %>
        </h1>
        <form class="flex flex-wrap space-y-5 text-zinc-400" action="/posts" method="post">
            <input class="outline-none p-2 border-1 rounded-lg border-zinc-800 w-full " type="text" name="content"
                placeholder="content">
            <input class="bg-blue-700 py-2 px-3 text-white rounded-lg w-full" type="submit" value="Create Post">
        </form>
        <p class="text-zinc-700 py-2">All posts</p>
        <div class=" h-full flex gap-3 flex-wrap ">

<% [...user.content].reverse().forEach(function(post) { %>                <div class="bg-zinc-800 text-white p-3 w-80 h-35 rounded-lg space-y-2">
                    <div class="flex justify-between items-center gap-3 ">
                        <p class="text-blue-600">@ <%= user.username %>
                        </p>
                        <p class="text-sm text-zinc-700">
                            <%= new Date(post.date).toDateString() %>
                        </p>

                    </div>
                    <p class="w-full h-13 overflow-hidden overflow-hidden break-words">
                        <%= post.content %>
                    </p>
                    <div class="text-blue-600 text-md flex gap-3">
                        <a href="/edit/<%= post._id %>">Edit</a>
                        <form action="/delete/<%= post._id %>" method="post">
                                <button type="submit" class="btn">Delete</button>
                        </form>

                    </div>
                </div>
                <% }) %>
        </div>
    </div>
</body>

</html>